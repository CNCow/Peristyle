{
  "manifest_version": 3,
  "name": "Peristyle",
  "version": "1.5",
  "description": "Your personal sanctuary on the web.",
  "chrome_url_overrides": { "newtab": "peristyle.html" },
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
     "storage"
  ],
  "host_permissions": [
    "https://www.bing.com/",
    "https://raw.githubusercontent.com/"
  ]
}
